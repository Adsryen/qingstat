{
    "main": "./workers/app.ts",
    "name": "qingstat",
    "account_id": "ef8e0352e51348a84bdf842749cb7491",
    "compatibility_flags": [
        "nodejs_compat_v2"
    ],
    "compatibility_date": "2024-12-13",
    "assets": {
        "binding": "ASSETS",
        "directory": "./build/client"
    },
    "analytics_engine_datasets": [
        {
            "binding": "WEB_COUNTER_AE",
            "dataset": "metricsDataset"
        }
    ],
    "r2_buckets": [
        {
            "bucket_name": "qingstat-daily-rollups",
            "preview_bucket_name": "qingstat-daily-rollups-dev",
            "binding": "DAILY_ROLLUPS"
        }
    ],
    "triggers": {
        "crons": [
            "0 2 * * *",
            "20 * * * *"
        ]
    },
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "qingstat",
            "database_id": "19666f37-1271-40fa-85ab-9d2de802fc6d",
            "migrations_dir": "./migrations"
        }
    ],
    "routes": [
        {
            "pattern": "pv.we-together.club",
            "custom_domain": true
        }
    ],
    "workers_dev": true,
    "durable_objects": {
        "bindings": [
            {
                "name": "PRESENCE",
                "class_name": "SitePresence"
            }
        ]
    },
    "migrations": [
        {
            "tag": "v1",
            "new_sqlite_classes": [
                "SitePresence"
            ]
        }
    ]
}
