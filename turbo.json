{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "outputs": ["dist/**"]
        },
        "@qingstat/server#build": {
            "dependsOn": ["^build", "@qingstat/server#copytracker"],
            "inputs": ["$TURBO_DEFAULT$", ".dev.vars"],
            "outputs": ["build/**"]
        },
        "@qingstat/server#copytracker": {
            "dependsOn": ["^@qingstat/tracker#build"],
            "outputs": ["public/tracker.js"]
        },
        "dev": {
            "dependsOn": ["^@qingstat/server#copytracker"],
            "inputs": ["$TURBO_DEFAULT$", ".dev.vars"],
            "cache": false,
            "persistent": true
        },
        "preview": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "deploy": {
            "dependsOn": ["build"],
            "cache": false
        },
        "test": {},
        "@qingstat/tracker#test": {
            "dependsOn": ["@qingstat/tracker#build"]
        },
        "test-ci": {
            "outputs": ["coverage/**"]
        },
        "@qingstat/tracker#test-ci": {
            "dependsOn": ["@qingstat/tracker#build"]
        },
        "lint": {
            "dependsOn": ["build"]
        },
        "typecheck": {
            "dependsOn": ["build"]
        },
        "@qingstat/tracker#publish": {
            "dependsOn": ["build"]
        }
    }
}
